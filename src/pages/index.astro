---
import Layout from '~/layouts/PageLayout.astro';
import HeroTypewriter from '~/components/widgets/HeroTypewriter';
import { getPermalink } from '~/utils/permalinks';
import { findLatestPosts } from '~/utils/blog';
import { findImage } from '~/utils/images';
import Image from '~/components/common/Image.astro';
import { Image as AstroImage } from 'astro:assets';
import logoImg from '~/assets/images/nobug-world-logo.png';

const metadata = {
  title: 'NobugWorld - 个人网站首页',
};

// Fetch latest posts for the textual list
const posts = await findLatestPosts({ count: 6 });
const postImages = await Promise.all(posts.map((post) => findImage(post.image)));
---

<Layout metadata={metadata}>
  <div class="max-w-3xl mx-auto px-6 py-12 md:py-20 font-sans text-slate-800 dark:text-slate-200">
    <!-- Hero Header section: Like DIYgod's "Hi, DIYgod" -->
    <header
      class="mb-14 flex flex-col md:flex-row md:items-center justify-between gap-8 border-b border-slate-100 dark:border-slate-800 pb-10"
    >
      <div>
        <h1 class="text-4xl md:text-5xl font-bold tracking-tight mb-4 inline-block">Hi, NobugWorld</h1>
        <div class="mb-4">
          <HeroTypewriter client:load />
        </div>
        <p class="text-md text-slate-600 dark:text-slate-400 max-w-lg leading-relaxed mb-4">
          写代码是热爱，记录生活是本能。这里是我的数字花园。<br />
          我是一个热爱折腾、正在探索世界的技术记录者。
        </p>

        <!-- 此刻 (Now) - Minimal text layout -->
        <div class="flex items-center gap-2 text-sm text-slate-500 dark:text-slate-400">
          <span class="relative flex h-2 w-2">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-green-400 opacity-75"></span>
            <span class="relative inline-flex rounded-full h-2 w-2 bg-green-500"></span>
          </span>
          <span>此刻 (Now): 正在探索世界 ☕️ 写代码</span>
        </div>
      </div>

      <!-- Avatar -->
      <div class="flex-shrink-0">
        <AstroImage
          src={logoImg}
          alt="NobugWorld Avatar"
          class="w-28 h-28 object-cover rounded-full shadow-sm hover:rotate-[360deg] transition-transform duration-1000 ease-in-out"
        />
      </div>
    </header>

    <main>
      <!-- 文章 Section -->
      <section
        class="mb-20 relative mt-12 border border-dashed border-slate-300 dark:border-slate-700 rounded-[2rem] p-6 sm:p-10"
      >
        <div class="absolute -top-5 left-6 sm:left-10 bg-page px-4">
          <h2 class="text-2xl md:text-3xl font-bold text-slate-800 dark:text-slate-100">文章</h2>
        </div>
        <div class="flex flex-col gap-10 mt-4 md:mt-2">
          {
            posts.map((post, index) => (
              <article class="flex flex-col sm:flex-row gap-4 sm:gap-6 items-start group">
                {postImages[index] && (
                  <a
                    href={getPermalink(post.permalink, 'post')}
                    class="flex-shrink-0 block w-full sm:w-32 md:w-40 aspect-video sm:aspect-square rounded-2xl overflow-hidden shadow-sm group-hover:shadow-md transition-shadow"
                  >
                    <Image
                      src={postImages[index]}
                      alt={post.title}
                      class="object-cover w-full h-full transform group-hover:scale-105 transition-transform duration-500"
                      width={200}
                      height={200}
                    />
                  </a>
                )}
                <div class="flex flex-col gap-2 flex-1 w-full">
                  <a
                    href={getPermalink(post.permalink, 'post')}
                    class="text-xl md:text-2xl font-bold tracking-tight text-slate-800 dark:text-slate-100 hover:text-blue-500 dark:hover:text-blue-400 transition-colors"
                  >
                    {post.title}
                  </a>
                  {post.excerpt && (
                    <p class="text-slate-600 dark:text-slate-400 leading-relaxed line-clamp-2 md:line-clamp-3">
                      {post.excerpt}
                    </p>
                  )}
                  <div class="flex flex-wrap items-center gap-x-4 gap-y-2 text-sm mt-1">
                    {post.category?.title && (
                      <a
                        href={getPermalink(post.category.slug, 'category')}
                        class="text-blue-600 dark:text-blue-400 hover:underline"
                      >
                        {post.category.title}
                      </a>
                    )}
                    {post.tags &&
                      post.tags.length > 0 &&
                      post.tags.map((tag) => (
                        <a
                          href={getPermalink(tag.slug, 'tag')}
                          class="text-slate-500 dark:text-slate-400 hover:text-slate-700 dark:hover:text-slate-300 transition-colors"
                        >
                          #{tag.title}
                        </a>
                      ))}
                    {(post.category?.title || (post.tags && post.tags.length > 0)) && (
                      <span class="text-slate-300 dark:text-slate-600">·</span>
                    )}
                    <time class="text-slate-400 font-mono" datetime={String(post.publishDate)}>
                      {new Date(post.publishDate).toISOString().split('T')[0].replace(/-/g, '/')}
                    </time>
                  </div>
                </div>
              </article>
            ))
          }
        </div>
        <div class="absolute -bottom-3 right-6 sm:right-10 bg-page px-4">
          <a
            href={getPermalink('/blog')}
            class="text-sm text-blue-500 hover:text-blue-600 dark:text-blue-400 dark:hover:text-blue-300 transition-colors"
            >所有文章 →</a
          >
        </div>
      </section>

      <!-- 轨迹与项目 Section -->
      <section
        class="mb-14 relative mt-16 border border-dashed border-slate-300 dark:border-slate-700 rounded-[2rem] p-6 sm:p-10"
      >
        <div class="absolute -top-5 left-6 sm:left-10 bg-page px-4">
          <h2 class="text-2xl md:text-3xl font-bold text-slate-800 dark:text-slate-100">轨迹 & 项目</h2>
        </div>
        <ul class="flex flex-col gap-4 mt-4 md:mt-2">
          <li
            class="flex flex-col sm:flex-row sm:items-baseline sm:justify-between gap-2 border-b border-slate-100 dark:border-slate-800/50 pb-4"
          >
            <div class="flex flex-col">
              <span class="text-lg font-medium">博客体系重构 (Astro)</span>
              <p class="text-sm text-slate-500 dark:text-slate-400 mt-1">
                采用 Astro 与 Tailwind，将网站从静态展示重构为纯粹的内容花园。
              </p>
            </div>
            <span class="text-xs font-mono text-slate-400">2026</span>
          </li>
          <li
            class="flex flex-col sm:flex-row sm:items-baseline sm:justify-between gap-2 border-b border-slate-100 dark:border-slate-800/50 pb-4"
          >
            <div class="flex flex-col">
              <span class="text-lg font-medium">记录生活 (Journey)</span>
              <p class="text-sm text-slate-500 dark:text-slate-400 mt-1">
                开始系统地记录技术与日常感悟，书写改变世界的代码。
              </p>
            </div>
            <span class="text-xs font-mono text-slate-400">2024</span>
          </li>
          <li
            class="flex flex-col sm:flex-row sm:items-baseline sm:justify-between gap-2 border-b border-slate-100 dark:border-slate-800/50 pb-4 border-0"
          >
            <div class="flex flex-col">
              <span class="text-lg font-medium">设计之路 (Design)</span>
              <p class="text-sm text-slate-500 dark:text-slate-400 mt-1">踏入设计学院，开启视觉与技术的跨界探索。</p>
            </div>
            <span class="text-xs font-mono text-slate-400">2018</span>
          </li>
        </ul>
      </section>

      <!-- 页面底部的纯文本引用 -->
      <section class="mt-20 text-center">
        <p class="text-sm text-slate-400 italic mb-2">"种一棵树最好的时间是十年前，其次是现在。"</p>
      </section>
    </main>
  </div>
</Layout>
